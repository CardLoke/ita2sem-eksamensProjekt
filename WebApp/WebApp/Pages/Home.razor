@using Core.Model;
@inject NavigationManager navigationManager;
@using Blazored.SessionStorage;
@inject ISessionStorageService sessionStorage;
@page "/"

<PageTitle>Home</PageTitle>

<h1>Session Sync</h1>

Welcome to Session Sync

@if (loggedIn != null)
{
    <button @onclick="AddStu">Add a studio</button>
}

@code
{
    
    public void AddStu()
    {
        navigationManager.NavigateTo("/AddStudio");
    }
    
    User? loggedIn;
    protected async override Task OnInitializedAsync()
    {
        loggedIn = await sessionStorage.GetItemAsync<User?>("user");
    }
}
