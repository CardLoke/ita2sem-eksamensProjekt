@using System.Net
@using Core.Model;
@inject NavigationManager navigationManager;
@using Blazored.SessionStorage;
@inject ISessionStorageService sessionStorage;
@inject HttpClient http
@page "/"
@using System.Threading.Tasks
@using WebApp.Components;

<div class="page">
    <PageTitle>Session Sync - Music Studios</PageTitle>

    <h1 class="page-title">Find Your Perfect Studio</h1>
    <p class="subtitle">Professional recording studios available for booking</p>
    <div class="filter-container">

        <div class="filter-group">
            <label>Max Price</label>
            <input type="number"
                   @bind="maxPrice" />
        </div>

        <div class="filter-group">
            <label>Min Capacity</label>
            <input type="number"
                   @bind="minCapacity" />
        </div>

        <div class="filter-group">
            <label>Search Equipment</label>
            <input type="text"
                   @bind="equipmentSearch" />
        </div>
        
        <div class="filter-group">
            <label>Sort By</label>

            <select @bind="sortBy" class="form-input">
                <option value="">None</option>
                <option value="price">Cheapest First</option>
                <option value="capacity">Largest Capacity First</option>
            </select>
        </div>
        
        <div class ="filter-group">
            <label> Search Studio </label>
            <input type ="text"
                   @bind="studioSearch"
                   class="form-input"/>
        </div>
        <button class="filter-group" id="private-btn" @onclick="ShowPrivateStudios">@privateString</button>

    </div>

    <div class="studios-grid">
        @if (studios == null || !studios.Any())
        {
            <p>No studios available at the moment.</p>
        }
        else
        {
            @foreach (var s in DisplayedStudios)
            {
                @if (s.Visibility == privateIf || s.Owner == loggedIn?.Username)
                {
                    <div class="studio-card">
                        <div class="studio-image">
                            <!-- Placeholder image - replace with real image later -->
                            <img src="https://www.sunsetsound.com/wp-content/uploads/2021/04/studio-1-4.jpg" alt="@s.StudioName"/>
                        </div>

                        <div class="studio-content">
                            <h3>@s.StudioName</h3>
                            <p class="description">@s.StudioDescription</p>

                            <div class="studio-info">
                                <p><strong>Equipment:</strong> @s.StudioEquipment</p>
                                <p><strong>Size:</strong> @s.StudioSize</p>
                                <p><strong>Address:</strong> @s.StudioAddress</p>
                            </div>

                            <div class="price">
                                @s.StudioPrice <span class="price-unit">kr / hour</span>
                            </div>

                            <div class="owner">Owned by <strong>@s.Owner</strong></div>

                            @if (loggedIn != null && s.Owner == loggedIn.Username)
                            {
                                <div class="delete-container">

                                    <button class="book-btn"
                                            @onclick='() => navigationManager.NavigateTo("/editStudio")'>
                                        Edit Studio
                                    </button>

                                    <button class="delete-btn"
                                            @onclick="() => Modal(s.Id)">
                                        Delete Studio
                                    </button>

                                </div>
                            }

                            @if (loggedIn != null && s.Owner != loggedIn.Username)
                            {
                                <div class="book-container">
                                    <button class="book-btn" @onclick="() => OpenBookingModal(s)">
                                        Book Studio
                                    </button>
                                </div>
                                
                            }
                            <div class="book-container">
                                <button class="book-btn"
                                        @onclick="() => OpenCalendar(s)">
                                    View Calendar
                                </button>
                            </div>
                            <div class="book-container">
                                <button class="book-btn" @onclick="() => ModalInvite(s)">Invite User</button>
                            </div>
                        </div>
                    </div>
                }
            }
        }
    </div>


    @if (loggedIn != null)
    {
        <div class="add-studio-container">
            <button class="add-studio-btn" @onclick="AddStu">
                + Add New Studio
            </button>
        </div>
    }

    <ModalDialog @ref="delete" Title="Confirm Deletion">
        Are you sure you want to delete this studio?
        <button class="btn btn-danger" @onclick="Delete">Yes, Delete</button>
        <button class="btn btn-secondary" @onclick="delete.Close">Cancel</button>
    </ModalDialog>
    <ModalBooking 
        IsOpen="@showBookingModal"
        IsOpenChanged="@((value) => showBookingModal = value)"
        Studio="@selectedStudio"
        OnBookingConfirmed="HandleBooking" />
    <ModalHourCalendar
        IsOpen="@showHourModal"
        IsOpenChanged="@((v) => showHourModal = v)"
        Studio="@selectedStudio"
        Bookings="@studioBookings" />
    <InviteUsersModal @ref="invite" Title="Invite Users">
        <label>Enter Username</label>
        <InputText id="invite" @bind-Value="tempUsername">
            
        </InputText>
        <p style="color: @errorColor">@error</p>
        <button class="btn btn-danger" @onclick="() => InviteCheck(tempUsername)">Invite</button>
        <button class="btn btn-secondary" @onclick="delete.Close">Cancel</button>
    </InviteUsersModal>
   
</div>
@code
{
    Invite? mInvite = new();
    Studio? tempStudio = new();
    string errorColor = "";
    string error = "";
    List<User> allUsers = new();
    string tempUsername = "";
    InviteUsersModal? invite;
    string privateIf = "Public";  
    List<Studio> privateStudios = new();
    string privateString = "Show Private Studios";
    private bool showHourModal = false;
    private DateTime selectedDate = DateTime.Today;
    private bool showCalendarModal = false;
    private List<BookingData> studioBookings = new();

    ModalDialog? delete;
    int tempId;

    User? loggedIn;
    List<Studio>? studios = new();
    int maxPrice = 0;
    int minCapacity = 0;
    string equipmentSearch = "";
    string sortBy = "";
    string studioSearch = "";


    private bool showBookingModal = false;
    private Studio? selectedStudio;

    private async Task OpenBookingModal(Studio studio)
    {
        selectedStudio = studio;
        showBookingModal = true;
    }

    private async Task HandleBooking(BookingData data)
    {
        data.Id = Random.Shared.Next();
        data.StudioOwner = selectedStudio.Owner;
        data.Name = loggedIn.Username;
        data.StudioName = selectedStudio.StudioName;
        data.StudioAddress = selectedStudio.StudioAddress;
        data.Status = "Pending";
        var response = await http.PostAsJsonAsync("http://localhost:5112/api/booking", data);

        showBookingModal = false;
    }

    protected async override Task OnInitializedAsync()
    {
        loggedIn = await sessionStorage.GetItemAsync<User?>("user");
        await LoadStudios();
    }

    private async Task LoadStudios()
    {
        studios = await http.GetFromJsonAsync<List<Studio>>("http://localhost:5112/api/studio");
        await InvokeAsync(StateHasChanged);
    }

    private IEnumerable<Studio> DisplayedStudios => privateIf == "Private"
     ? privateStudios
     : GetFilteredStudios();

    private IEnumerable<Studio> GetFilteredStudios()
    {
        if (studios == null) return new List<Studio>();

        var result = studios.Where(s =>
            (maxPrice == 0 || s.StudioPrice <= maxPrice) &&
            (minCapacity == 0 || s.StudioSize >= minCapacity) &&
            (string.IsNullOrWhiteSpace(equipmentSearch) ||
             s.StudioEquipment.Contains(equipmentSearch, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(studioSearch) ||
             s.StudioName.Contains(studioSearch, StringComparison.OrdinalIgnoreCase))
        );

        if (sortBy == "price")
            result = result.OrderBy(s => s.StudioPrice);
        else if (sortBy == "capacity")
            result = result.OrderByDescending(s => s.StudioSize);

        return result;
    }




    public void AddStu()
    {
        navigationManager.NavigateTo("/AddStudio");
    }

    public void Modal(int id)
    {
        tempId = id; 
        delete?.Open();
    }

    public async Task Delete()
    {
        if (tempId == 0) return;

        var response = await http.DeleteAsync($"http://localhost:5112/api/studio/delete/{tempId}");

        if (response.IsSuccessStatusCode)
        {
            delete?.Close();
            await LoadStudios();     

        }
    }
    private async Task OpenCalendar(Studio studio)
    {
        selectedStudio = studio;
        showHourModal = true; // open immediately (better UX)

        studioBookings = new();

        try
        {
            studioBookings =
                await http.GetFromJsonAsync<List<BookingData>>(
                    $"http://localhost:5112/api/booking/studio/{studio.Id}")
                ?? new();
            Console.WriteLine($"Loaded {studioBookings.Count} bookings for studio {studio.StudioName}");
        }
        catch { }

        StateHasChanged();
    }
    public async Task ShowPrivateStudios()
    {
        // Toggle between Public and Private mode
        if (privateIf == "Public")
        {
            privateIf = "Private";
            privateString = "Show Public Studios";

            // Show only private studios the user owns or has been invited to

            foreach (var x in studios ?? new List<Studio>())
            {
                if (x.Visibility == "Private" &&
                    (x.Owner == loggedIn?.Username ||
                     x.PrivateUsers != null && x.PrivateUsers.Contains(loggedIn?.Username)))
                {
                    Console.WriteLine(loggedIn.Username);
                    privateStudios.Add(x);
                }
            }
            studios = privateStudios.ToList();   // Make a copy
            foreach(var x in studios)
            {
                Console.WriteLine(x.StudioName);
            }
        }
        else
        {
            privateIf = "Public";
            privateString = "Show Private Studios";

            // Reset to show all studios
            await LoadStudios();   // This reloads the full list from API
            privateStudios.Clear();
        }

        StateHasChanged();
    }
    public async Task InviteCheck(string username)
    {
        allUsers = await http.GetFromJsonAsync<List<User>>("http://localhost:5112/api/user");
        bool status = false;
        foreach(User x in allUsers)
        {
            if (x.Username == username)
            {
                status = true;
                break;
            } 
        }
        if (status == false)
        {
            errorColor = "#ff0000";
            error = "User does not exist";
        }
        else
        {
            errorColor = "#00ff00";
            error = "Invitation sent!";
            
            
                mInvite.Username = username;
                mInvite.Studio = tempStudio;
                mInvite.Id = Random.Shared.Next();
                Console.WriteLine("hej");
                await http.PostAsJsonAsync("http://localhost:5112/api/invite",mInvite);
            

        }

    }
    public void ModalInvite(Studio s)
    {
        tempStudio = s;
        invite.Open();
    }


}