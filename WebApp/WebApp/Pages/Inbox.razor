@using System.Net
@using Core.Model;
@inject NavigationManager navigationManager;
@using Blazored.SessionStorage;
@inject ISessionStorageService sessionStorage;
@inject HttpClient http
@using System.Threading.Tasks
@using WebApp.Components;
@using static WebApp.Config;
@page "/inbox"


<div class="page">
    <PageTitle>Session Sync - Inbox</PageTitle>

    <h1 class="page-title">Inbox</h1>
    <p class="subtitle">Manage your studio booking requests</p>

    <div class="inbox-container">

        <!-- Your Requests -->
        <section class="inbox-section">
            <h2 class="section-title">Your Requests</h2>
            <div class="requests-grid">
                @if (myRequests == null || !myRequests.Any())
                {
                    <p class="no-data">You haven't made any booking requests yet.</p>
                }
                else
                {
                    @foreach (var request in myRequests)
                    {
                        <div class="booking-card @(request.Status?.ToLower() ?? "")">
                            <div class="card-header">
                                <h3>@request.StudioName</h3>
                                <span class="status @(request.Status?.ToLower() ?? "")">@request.Status</span>
                            </div>

                            <div class="card-body">
                                <p><strong>Owner:</strong> @request.StudioOwner</p>
                                <p><strong>Address:</strong> @request.StudioAddress</p>
                                <p><strong>Date:</strong> @request.Date.ToShortDateString()</p>
                                <p><strong>Time:</strong> @request.StartTime - @request.EndTime</p>
                                <p><strong>Attendees:</strong> @request.Attendees</p>

                                @if (!string.IsNullOrEmpty(request.Notes))
                                {
                                    <p><strong>Notes:</strong> @request.Notes</p>
                                }


                                @if ((request.Status ?? "") != "Cancelled" &&
                                     (request.Status ?? "") != "Rejected")
                                {
                                    <div class="card-actions">
                                        <button class="btn reject-btn"
                                                @onclick='() => UpdateStatus(request.Id, "Cancelled")'>
                                            Cancel booking
                                        </button>
                                    </div>
                                }

                            </div>
                        </div>
                    }
                }
            </div>
        </section>

        <!-- Your Studios' Requests -->
        <section class="inbox-section">
            <h2 class="section-title">Your Studios' Requests</h2>
            <div class="requests-grid">
                @if (myStudioRequests == null || !myStudioRequests.Any())
                {
                    <p class="no-data">No one has requested to book your studios yet.</p>
                }
                else
                {
                    @foreach (var request in myStudioRequests)
                    {
                        <div class="booking-card @(request.Status?.ToLower() ?? "")">
                            <div class="card-header">
                                <h3>@request.StudioName</h3>

                                <span class="status @(request.Status?.ToLower() ?? "")">
                                    @request.Status
                                </span>

                                @if (request.Status == "Rejected")
                                {
                                    <button class="close-btn"
                                            @onclick="() => Modal(request.Id)">
                                        ✕
                                    </button>
                                }
                            </div>

                            <div class="card-body">
                                <p><strong>Request from:</strong> @request.Name</p>
                                <p><strong>Address:</strong> @request.StudioAddress</p>
                                <p><strong>Date:</strong> @request.Date.ToShortDateString()</p>
                                <p><strong>Time:</strong> @request.StartTime - @request.EndTime</p>
                                <p><strong>Attendees:</strong> @request.Attendees</p>

                                @if (!string.IsNullOrEmpty(request.Notes))
                                {
                                    <p><strong>Notes:</strong> @request.Notes</p>
                                }
                            </div>

                            <div class="card-actions">
                                <button class="btn accept-btn"
                                        @onclick='() => UpdateStatus(request.Id, "Accepted")'>
                                    Accept
                                </button>

                                <button class="btn reject-btn"
                                        @onclick='() => UpdateStatus(request.Id, "Rejected")'>
                                    Reject
                                </button>
                            </div>

                        </div>
                    }
                }
            </div>
        </section>
        
        <!-- Your Private Studio Invites -->
        <section class="inbox-section">
            <h2 class="section-title">Your Private Studio Invites</h2>
            <div class="requests-grid">
                @if (mInvites == null || !mInvites.Any())
                {
                    <p class="no-data">You don't have any invitations at this time.</p>
                }
                else
                {
                    @foreach (var invite in mInvites)
                    {
                        <div class="booking-card">
                            <div class="card-header">
                                <h3>@invite.Studio.StudioName</h3>
                                <span class="status pending">Pending Invite</span>
                            </div>
                            <div class="card-body">
                                <p><strong>Owner:</strong> @invite.Studio.Owner</p>
                                <p><strong>Address:</strong> @invite.Studio.StudioAddress</p>
                                @if (!string.IsNullOrEmpty(invite.Studio.StudioDescription))
                                {
                                    <p><strong>Description:</strong> @invite.Studio.StudioDescription</p>
                                }
                            </div>
                            <div class="card-actions">
                                <button class="btn accept-btn"
                                        @onclick="() => ApproveInvite(invite)">
                                    Accept Invitation
                                </button>
                                <button class="btn reject-btn"
                                        @onclick="() => RejectInvite(invite.Id)">
                                    Decline
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </section>
        </div>
        </div>

<ModalDialog @ref="delete" Title="Confirm Deletion">
    Are you sure you want to delete your request?
    <button class="btn btn-danger" @onclick="Delete">Yes, Delete</button>
    <button class="btn btn-secondary" @onclick="delete.Close">Cancel</button>
</ModalDialog>

@code {
    private User? loggedIn;
    private List<BookingData>? myRequests;
    private List<BookingData>? myStudioRequests;
    List<Invite>? mInvites = new();

    ModalDialog? delete;
    int tempId;

    protected override async Task OnInitializedAsync()
    {
        loggedIn = await sessionStorage.GetItemAsync<User?>("user");
        mInvites = await http.GetFromJsonAsync<List<Invite>>($"{ServerUrl}/api/invite/get/{loggedIn.Username}");
        if (loggedIn != null)
        {
            await LoadRequests();
        }
    }

    private async Task LoadRequests()
    {
        var requestResponse = await http.PostAsJsonAsync($"{ServerUrl}/api/booking/requests", loggedIn);
        var studioResponse = await http.PostAsJsonAsync($"{ServerUrl}/api/booking/studioRequests", loggedIn);

        myRequests = await requestResponse.Content.ReadFromJsonAsync<List<BookingData>>();
        myStudioRequests = await studioResponse.Content.ReadFromJsonAsync<List<BookingData>>();

        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdateStatus(int bookingId, string newStatus)
    {
        Console.WriteLine("hej");

        await http.PutAsJsonAsync($"{ServerUrl}/api/booking/status/{bookingId}", newStatus);

        await LoadRequests();
    }

    public async Task Delete()
    {
        var response = await http.DeleteAsync($"{ServerUrl}/api/booking/delete/{tempId}");

        if (response.IsSuccessStatusCode)
        {
            delete?.Close();
            await LoadRequests();
        }
    }

    public void Modal(int id)
    {
        tempId = id;
        delete?.Open();
    }
    public async Task RejectInvite(int id)
    {
        await http.DeleteAsync($"{ServerUrl}/api/invite/delete/{id}");
        await InvokeAsync(StateHasChanged);
    }
    public async Task ApproveInvite(Invite invite)
    {
        await http.PutAsJsonAsync($"{ServerUrl}/api/Studio/invite", invite);
        await http.DeleteAsync($"{ServerUrl}/api/invite/delete/{invite.Id}");
        await InvokeAsync(StateHasChanged);
    }
}