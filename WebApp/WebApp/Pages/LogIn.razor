@page "/logIn"
@inject HttpClient http
@using Core.Model;
@using Blazored.SessionStorage
@inject ISessionStorageService sessionStorage
@inject NavigationManager navManager



@using Core.Model;

<PageTitle>Log ind - Session Sync</PageTitle>

<div class="login-page">
    <div class="login-container">

        <div class="login-header">
            <h1>Velkommen tilbage</h1>
            <p>Log ind for at administrere dine studier</p>
        </div>

        <div class="form-group">
            <label>Brugernavn</label>
            <InputText @bind-Value="username"
                       class="form-input"
                       placeholder="Indtast dit brugernavn" />
        </div>

        <div class="form-group">
            <label>Adgangskode</label>
            <InputText type="password"
                       @bind-Value="password"
                       class="form-input"
                       placeholder="Indtast din adgangskode" />
        </div>

        @if (!string.IsNullOrEmpty(errorText))
        {
            <div class="error-message">
                ⚠️ @errorText
            </div>
        }

        <button class="login-btn" @onclick="OnClickLogin">
            Log ind
        </button>

        <div class="login-footer">
            <button class="back-btn" @onclick="Hjem">
                ← Tilbage til forsiden
            </button>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string errorText = "";

    private async Task OnClickLogin()
    {
        errorText = "";

        var loginRequest = new LoginRequest
        {
            Username = username,
            Password = password
        };

        var response = await http.PostAsJsonAsync("http://localhost:5112/api/user/logIn", loginRequest);

        if (response.IsSuccessStatusCode)
        {
            var loggedIn = await response.Content.ReadFromJsonAsync<User>();

            if (loggedIn != null)
            {
                await sessionStorage.SetItemAsync("user", loggedIn);
                navManager.NavigateTo("/", true);
            }
            else
            {
                errorText = "Login mislykkedes. Forkert data modtaget.";
            }
        }
        else
        {
            errorText = "Forkert brugernavn eller adgangskode.";
        }
    }

    private void Hjem()
    {
        navManager.NavigateTo("/");
    }
}