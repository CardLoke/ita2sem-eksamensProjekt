@page "/AddStudio"
@inject HttpClient http
@using Core.Model;
@inject NavigationManager navigationManager;
@using Blazored.SessionStorage;
@inject ISessionStorageService sessionStorage;

@using Core.Model;

<PageTitle>Add New Studio - Session Sync</PageTitle>

<div class="add-studio-page">
    <div class="page-header">
        <h1>Add Your Studio</h1>
        <p>Share your studio with musicians and producers</p>
    </div>

    <div class="form-container">
        <div class="studio-form">

            <div class="form-group">
                <label>Studio Name</label>
                <InputText @bind-Value="aNewStudio.StudioName"
                           class="form-input"
                           placeholder="e.g. Neon Sound Studio" />
            </div>

            <div class="form-group">
                <label>Studio Size (Max people)</label>
                <InputNumber @bind-Value="aNewStudio.StudioSize"
                             class="form-input"
                             placeholder="How many people can fit?" />
            </div>

            <div class="form-group">
                <label>Description</label>
                <InputTextArea @bind-Value="aNewStudio.StudioDescription"
                               class="form-input textarea"
                               placeholder="Describe your studio, atmosphere, vibe, etc..."
                               rows="4" />
            </div>

            <div class="form-group">
                <label>Equipment</label>
                <InputText @bind-Value="aNewStudio.StudioEquipment"
                           class="form-input"
                           placeholder="e.g. Neumann microphones, Yamaha monitors, UAD interfaces..." />
            </div>

            <div class="form-group">
                <label>Hourly Price (kr)</label>
                <InputNumber @bind-Value="aNewStudio.StudioPrice"
                             class="form-input"
                             placeholder="e.g. 450" />
            </div>

            <div class="form-group">
                <label>Address</label>
                <InputText @bind-Value="aNewStudio.StudioAddress"
                           class="form-input"
                           placeholder="Full address of the studio" />
            </div>
            <div class="form-group">
                <label>Synlighed</label>

                <select @bind="aNewStudio.Visibility" class="form-input">
                    <option value="Offentlig">Offentlig</option>
                    <option value="Privat">Privat</option>
                </select>
            </div>
            
            
            <button class="submit-btn" @onclick="OnClickRegisterStudio">
                Register Studio
            </button>
        </div>
    </div>
</div>

@code {
    private Studio aNewStudio = new Studio();
    User? loggedIn;

    protected async override Task OnInitializedAsync()
    {
        loggedIn = await sessionStorage.GetItemAsync<User?>("user");
        if (loggedIn == null)
        {
            navigationManager.NavigateTo("/");
        }
    }

    private async Task OnClickRegisterStudio()
    {
        if (string.IsNullOrWhiteSpace(aNewStudio.StudioName))
        {
            
            return;
        }

        aNewStudio.Owner = loggedIn?.Username;
        aNewStudio.Id = Random.Shared.Next(); 

        var response = await http.PostAsJsonAsync("http://localhost:5112/api/studio/register", aNewStudio);

        if (response.IsSuccessStatusCode)
        {
            navigationManager.NavigateTo("/"); 
        }
    }
}