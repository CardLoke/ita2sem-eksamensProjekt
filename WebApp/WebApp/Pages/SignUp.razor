@page "/signUp"
@inject HttpClient http
@using Core.Model
@using Blazored.SessionStorage
@inject NavigationManager navigationManager;
@using WebApp.Components;

<div class="signup-page">
    <div class="form-container">
        <div class="studio-form">
            <h3 class="form-title">Sign Up</h3>

            <div class="form-group">
                <label>Username</label>
                <InputText @bind-Value="aNewUser.Username"
                           class="form-input"
                           placeholder="Enter username" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="aNewUser.Mail"
                           class="form-input"
                           placeholder="Enter email" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <InputText @bind-Value="aNewUser.Password"
                           class="form-input"
                           placeholder="Enter password" />
            </div>

            <div class="form-group">
                <label>Role</label>
                <select @bind="aNewUser.Role" class="form-input">
                    <option value="">Select Role</option>
                    <option value="Studieejer">Studieejer</option>
                    <option value="Studielejer">Studielejer</option>
                    <option value="Producer">Producer</option>
                </select>
            </div>
            <button id="opretBtn" @onclick="OnClickOpret">Opret bruger</button>
        </div>
    </div>
</div>


<ModalDialog @ref="signUp" Title="Confirm Deletion">
    @message
    <button @onclick=" toLogin">Okay</button>
</ModalDialog>

@code {

    ModalDialog? signUp;

    private User aNewUser = new User();
    string message = "";

    private async Task OnClickOpret()
    {
        aNewUser.Id = Random.Shared.Next();


        var result = await http.PostAsJsonAsync("http://localhost:5112/api/user/signUp", aNewUser);


        aNewUser = new();


        if (result.Content != null)
        {
            message = await result.Content.ReadAsStringAsync();
            signUp.Open();
        }
        else
        {
            message = string.Empty;
        }

    }

    public void Hjem()
    {
        navigationManager.NavigateTo("/");
    }
    public void toLogin()
    {
        if (message == "Sign Up was succesfull!")
        {
            signUp.Close();
            navigationManager.NavigateTo("login");
        }
        else
        {
            signUp.Close();
        }
    }
    }
